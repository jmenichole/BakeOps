# Supabase Configuration
# Get these values from your Supabase project dashboard
# Go to: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_SECRET_KEY=your-service-role-secret-key

# Resend (Email Service)
RESEND_API_KEY=re_your-resend-api-key

# AI Image Generation (Google Gemini — default)
# Get your API key at https://aistudio.google.com/app/apikey
AI_IMAGE_API_KEY=AIza-your-google-ai-studio-key
# AI_IMAGE_API_URL and AI_IMAGE_MODEL default to Gemini; override only if using a different provider.
# AI_IMAGE_API_URL=https://generativelanguage.googleapis.com/v1beta
# AI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
# For higher-quality text-to-image (no reference image support): imagen-3.0-generate-002

# Vercel Cron Security
# Required for /api/traction-report — use a long random string
CRON_SECRET=your-random-secret-here

# Optional: Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Admin Access Control
# Comma-separated list of IPs allowed to access /admin
ALLOWED_ADMIN_IP=your-ip-here,127.0.0.1

# Edge Function Security
# Required for /supabase/functions/stats
INTERNAL_STATS_SECRET=your-internal-stats-secret-here
